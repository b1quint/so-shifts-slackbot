# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Google Sheets spreadsheet id (from the URL: /spreadsheets/d/<SHEET_ID>/edit)
SHIFT_SHEET_ID=

# Slack bot token (xoxb-...) — requires usergroups:read and usergroups:write scopes
SLACK_BOT_TOKEN=

# Optional: override the default Slack user group handles (e.g. for testing).
# Uncomment and set to redirect writes to different groups.
# SLACK_GROUP_SUPSCI=test-slackbot-supsci-shift
# SLACK_GROUP_DAY=test-slackbot-dayos-shift
# SLACK_GROUP_NIGHT=test-slackbot-nightos-shift
