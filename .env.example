# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Google Sheets spreadsheet id (from the URL: /spreadsheets/d/<SHEET_ID>/edit)
SHIFT_SHEET_ID=

# Slack bot token (xoxb-...) — requires usergroups:read and usergroups:write scopes
SLACK_BOT_TOKEN=

# Optional: override the default Slack user group handles
# SLACK_GROUP_SUPSCI=summit-sup-sci
# SLACK_GROUP_DAY=os-day-shift
# SLACK_GROUP_NIGHT=os-night-shift
